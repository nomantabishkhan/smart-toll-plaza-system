DJANGO_SECRET_KEY=change-me
DEBUG=true
ALLOWED_HOSTS=localhost,127.0.0.1
TIME_ZONE=Asia/Karachi

# Database: set USE_SQLITE=true to avoid Postgres locally
USE_SQLITE=true
POSTGRES_DB=smarttoll
POSTGRES_USER=smarttoll
POSTGRES_PASSWORD=smarttoll
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432

# Celery broker (required unless USE_EAGER_CELERY=true). For Windows without WSL, use a cloud Redis URL.
REDIS_URL=redis://your-cloud-redis:6379/0
USE_EAGER_CELERY=true

OPENVINO_MODEL_XML=../openvino file/best.xml
OPENVINO_MODEL_BIN=../openvino file/best.bin
