DJANGO_SECRET_KEY=dev-local-key
DEBUG=true
ALLOWED_HOSTS=localhost,127.0.0.1
TIME_ZONE=Asia/Karachi
USE_SQLITE=true
POSTGRES_DB=smarttoll
POSTGRES_USER=smarttoll
POSTGRES_PASSWORD=smarttoll
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432

# Celery Configuration
# IMPORTANT: Set to "false" for ASYNC mode (prevents frontend freezing)
# Set to "true" only for debugging (synchronous, blocks web server)
USE_EAGER_CELERY=false

# YOLOv8 Model Configuration
# Path to your trained YOLOv8 .pt file (use forward slashes)
YOLO_MODEL_PATH=D:/pc data/projects/fyp smart toll plaza audit system/pt/best.pt

# Legacy OpenVINO paths (not used with YOLOv8, kept for reference)
OPENVINO_MODEL_XML=../openvino file/best.xml
OPENVINO_MODEL_BIN=../openvino file/best.bin

